<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(0, 0, 0, 0.5);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 40%);
		position: sticky;
		top: 0;
		z-index: 10;
		backdrop-filter: blur(6px);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: #f0e8e7;
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
